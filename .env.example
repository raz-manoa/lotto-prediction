# Database
# Local: postgresql://YOUR_USER@localhost:5432/lotto?schema=public
# Vercel + Neon: set DATABASE_URL to POSTGRES_URL_NON_POOLING from Vercel env vars
DATABASE_URL="postgresql://YOUR_USER@localhost:5432/lotto?schema=public"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Encryption key for user API keys (32 bytes hex = 64 chars)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="your-64-char-hex-key-here"
